# KEEP THESE FILES
# ============================================================================

# Important: Use ! to negate ignore for essential files
!.gitignore
!.gitkeep
!README.md
!LICENSE
!requirements.txt
!package.json
!package-lock.json
!tsconfig.json
!vite.config.ts
!alembic.ini
!Dockerfile
!docker-compose.yml
!.env.example

# Keep empty directories with .gitkeep
!**/.gitkeep
