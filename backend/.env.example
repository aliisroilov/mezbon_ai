# ============================================================================
# MEZBON AI - ENVIRONMENT VARIABLES (EXAMPLE)
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to git!
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/mezbon_dev
DATABASE_URL_SYNC=postgresql://username:password@localhost:5432/mezbon_dev

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-secret-key-here-64-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-here-64-chars
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your-encryption-key-here-64-chars

# ============================================================================
# AI SERVICES
# ============================================================================

# Gemini AI (get from: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Muxlisa AI (Uzbek/Russian STT/TTS)
MUXLISA_API_URL=https://service.muxlisa.uz/api/v2
MUXLISA_API_KEY=your-muxlisa-api-key-here
MUXLISA_MOCK=false

# Google Cloud Speech (optional fallback)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# ============================================================================
# FACE RECOGNITION
# ============================================================================
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_DEVICE=cpu

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ============================================================================
# PAYMENT GATEWAYS (UZBEKISTAN)
# ============================================================================
UZCARD_MERCHANT_ID=your-uzcard-merchant-id
HUMO_MERCHANT_ID=your-humo-merchant-id
CLICK_MERCHANT_ID=your-click-merchant-id
PAYME_MERCHANT_ID=your-payme-merchant-id

# ============================================================================
# PRINTER SETTINGS
# ============================================================================
PRINTER_TYPE=network
PRINTER_HOST=10.99.0.184
PRINTER_PORT=9100

# For USB printer:
# PRINTER_TYPE=usb
# PRINTER_VENDOR_ID=0x4B43
# PRINTER_PRODUCT_ID=0x3830

# ============================================================================
# CRM INTEGRATIONS (OPTIONAL)
# ============================================================================
BITRIX24_WEBHOOK_URL=
AMO_CRM_API_KEY=

# ============================================================================
# EMAIL (OPTIONAL)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@mezbon.uz

# ============================================================================
# SMS (OPTIONAL)
# ============================================================================
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=your-email@example.com
ESKIZ_PASSWORD=your-password

# ============================================================================
# FILE STORAGE
# ============================================================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# ============================================================================
# PERFORMANCE
# ============================================================================
WORKERS=4
MAX_CONNECTIONS=100
TIMEOUT=30

# ============================================================================
# MONITORING (OPTIONAL)
# ============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================================
# NOTES
# ============================================================================
# Production values:
# - Set APP_ENV=production
# - Set DEBUG=false
# - Use strong passwords and secrets
# - Enable HTTPS for CORS_ORIGINS
# - Configure proper firewall rules
# - Enable monitoring tools
# ============================================================================
